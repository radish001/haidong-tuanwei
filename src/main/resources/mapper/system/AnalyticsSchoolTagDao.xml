<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.haidong.tuanwei.system.dao.AnalyticsSchoolTagDao">

    <select id="findAllTagIds" resultType="long">
        select tag_id
        from sys_analytics_school_tag
        order by tag_id
    </select>

    <delete id="deleteAll">
        delete from sys_analytics_school_tag
    </delete>

    <delete id="deleteByTagId">
        delete from sys_analytics_school_tag
        where tag_id = #{tagId}
    </delete>

    <insert id="insert">
        insert into sys_analytics_school_tag (tag_id)
        values (#{tagId})
    </insert>
</mapper>
