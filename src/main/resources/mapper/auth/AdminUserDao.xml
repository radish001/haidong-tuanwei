<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.haidong.tuanwei.auth.dao.AdminUserDao">

    <resultMap id="AdminUserResultMap" type="com.haidong.tuanwei.auth.entity.AdminUser">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="nickname" column="nickname"/>
        <result property="phone" column="phone"/>
        <result property="enabled" column="enabled"/>
    </resultMap>

    <select id="findByUsername" resultMap="AdminUserResultMap">
        select id, username, password, nickname, phone, enabled
        from sys_user
        where username = #{username}
        limit 1
    </select>

    <select id="findRoleCodesByUserId" resultType="string">
        select r.role_code
        from sys_role r
                 inner join sys_user_role ur on ur.role_id = r.id
        where ur.user_id = #{userId}
          and r.enabled = 1
        order by r.id
    </select>
</mapper>
